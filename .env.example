BOT_TOKEN=your_telegram_bot_token
WEBHOOK_URL=                        # optional; uses long-polling if empty
WEBHOOK_SECRET=your_webhook_secret  # optional; used only when WEBHOOK_URL is set
BOT_SECRET=your_admin_panel_secret  # protects /api/v1/telegram/admin/* from Mini App
ADMIN_API_KEY=                      # optional legacy key for script access
API_PORT=8000
ADMIN_USERS=123456789               # comma-separated Telegram user IDs
LOG_LEVEL=INFO
WEBAPP_URL=https://scalata.ammirabet.com/api/v1/telegram/app/nuova
WEBAPP_ADMIN_URL=https://scalata.ammirabet.com/api/v1/telegram/app/admin
